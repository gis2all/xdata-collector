# Required: fill in X auth cookies before running the collector.
# These values come from the cookies of an already logged-in https://x.com session.
# Do not commit them to git and do not share them with others.
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# Optional helper: browser hint for local tooling or troubleshooting, e.g. edge
TWITTER_BROWSER=

# Optional helper: browser profile hint used by local X tooling
TWITTER_CHROME_PROFILE=
